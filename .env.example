# Gmail / Google Workspace account used to send the "Start a project" form.
# This account authenticates to smtp.gmail.com and sends the email.
SMTP_USER=your-sending-account@yourdomain.com

# App Password generated for SMTP_USER (NOT your regular login password).
# Google Account -> Security -> 2-Step Verification -> App Passwords.
# Requires 2-Step Verification to be enabled on the account.
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where the form submissions should land.
MAIL_TO=info@qepilot.com

# Backend port (optional, defaults to 3001)
API_PORT=3001
