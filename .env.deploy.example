# Copy to .env.deploy and fill in values from hPanel → Files → FTP Accounts.
# Used only by: npm run deploy:hostinger:upload

FTP_SERVER=ftp.YOUR_HOSTINGER_HOST
FTP_USERNAME=u000000000
FTP_PASSWORD=
# Trailing slash. Use your Node.js application root from hPanel.
FTP_REMOTE_DIR=/domains/qepilot.live/public_html/
